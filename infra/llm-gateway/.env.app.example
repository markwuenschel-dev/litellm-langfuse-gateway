# =============================================================================
# Application runtime env (NOT the proxy container)
# =============================================================================
# Copy into your app's secret store / local .env for that service.
# Never put these values into the LiteLLM Compose .env as a substitute for
# provider credentials — this file is for *callers* of the gateway only.
#
# Full wiring guide: docs/llm-platform/app-wiring.md
# =============================================================================

# OpenAI-compatible base URL of the gateway (must include /v1)
LITELLM_BASE_URL=http://localhost:4000/v1

# Virtual key from: uv run llg keys create ...
# Must start with sk-  — never use LITELLM_MASTER_KEY here
LITELLM_VIRTUAL_KEY=

# Stable alias from config/llm/model-aliases.yaml (default product model)
LITELLM_MODEL=llm-general

# Refuse master key if it appears in the process env (default: on)
LLG_DISALLOW_MASTER=1

# Optional identity for metadata / logging
# SERVICE_NAME=myapp
# ENVIRONMENT=development
# GIT_SHA=dev

# -----------------------------------------------------------------------------
# Optional: app-level Langfuse (root traces for multi-step workflows)
# The PROXY already exports per-generation telemetry. Only set these if the
# app instruments its own Langfuse root/spans (retrieval, tools, agents).
# Use a project/keys appropriate for the app; do not reuse proxy secrets
# in frontend or browser code.
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# =============================================================================
# NEVER set in application runtime (proxy / ops only)
# =============================================================================
# OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, XAI_API_KEY, ...
# LITELLM_MASTER_KEY
# LITELLM_SALT_KEY
# POSTGRES_PASSWORD / DATABASE_URL (proxy DB)
# REDIS_PASSWORD
