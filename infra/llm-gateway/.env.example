# =============================================================================
# LiteLLM + Langfuse Gateway — environment template (CANONICAL)
# =============================================================================
# Copy to .env in *this* directory only and fill real values:
#   cp infra/llm-gateway/.env.example infra/llm-gateway/.env
# Never use a repo-root .env for the gateway (root docker-compose.yml is an
# include shim that loads env from this directory). Never commit .env.
#
# Non-secret per-environment knobs (timeouts, log level, redis_required, …)
# live in config/llm/environments/{development,staging,production}.yaml
# — not here.
#
# Generate bootstrap secrets (master, salt, DB/redis passwords):
#   uv run python scripts/generate_secrets.py
# =============================================================================

# ---------------------------------------------------------------------------
# Hierarchy (who holds what)
# ---------------------------------------------------------------------------
# | Class              | Examples                              | Where values live          |
# |--------------------|---------------------------------------|----------------------------|
# | Admin bootstrap    | LITELLM_MASTER_KEY                    | Secret manager / local .env|
# | Encryption root    | LITELLM_SALT_KEY (**permanent**)      | Offline backup + SM only   |
# | DB / cache         | POSTGRES_PASSWORD, REDIS_PASSWORD     | Secret manager / local .env|
# | Provider credentials | OPENAI_*, ANTHROPIC_*, …            | Proxy env only (not apps)  |
# | Observability      | LANGFUSE_PUBLIC_KEY, SECRET_KEY       | Secret manager / local .env|
# | App traffic auth   | LITELLM_VIRTUAL_KEY (per app/env)     | App secret store           |
#
# Secret manager mapping (pick platform at deploy; inject same env names):
#   AWS Secrets Manager / SSM Parameter Store
#   GCP Secret Manager
#   Azure Key Vault
#   Doppler / 1Password / Vault
# Map each secret name below 1:1 into container/runtime env. Do not rename
# at the app boundary without updating compose and litellm-config references.
#
# Dev vs staging vs prod (values differ; names do not):
#   development — local .env; weak placeholders OK only on empty DBs; Redis off
#   staging     — secret manager; production-like strength; Redis if multi-replica
#   production  — secret manager only; salt from offline escrow; Redis if multi-replica
# See also: docs/llm-platform/incident-recovery.md

# =============================================================================
# LiteLLM proxy
# =============================================================================

# Master key: ADMIN BOOTSTRAP ONLY.
# - Create virtual keys for applications; never ship master key to apps/CI clients.
# - Rotatable with an admin procedure (invalidate old, issue new, update operators).
# - Compose fails boot if unset.
LITELLM_MASTER_KEY=sk-change-me-master

# Salt key: PERMANENT encryption secret for proxy data at rest.
# - Generate ONCE per environment (dev/staging/prod each have their own).
# - Store offline (printed escrow / HSM / sealed backup) AND in the secret manager.
# - Must be IDENTICAL across all proxy replicas that share the same Postgres.
# - NEVER rotate casually. Changing it makes existing encrypted DB secrets unreadable.
# - If lost: restore the original value from offline backup — do NOT generate a new
#   salt against a DB that already has encrypted rows. See incident-recovery.md.
LITELLM_SALT_KEY=sk-change-me-salt-permanent

# Optional override of the compose default pin (must include tag AND @sha256: digest).
# Default is set in compose.yaml — see upgrade-notes.md for bump procedure.
# LITELLM_IMAGE=ghcr.io/berriai/litellm:v1.92.0@sha256:9ef6f45bc0104940571765e610c52a1d761b5ec85efcd193795281086ee61277

# Proxy listen port on the host (container always uses 4000)
LITELLM_PORT=4000

# Model registry: YAML (litellm-config.yaml) is source of truth.
# Keep False so Admin UI/DB model edits are not a second authority.
# (Also documented in config/llm/environments/*.yaml as store_model_in_db: false)
STORE_MODEL_IN_DB=False

# Optional UI credentials (if enabled by your LiteLLM version/image).
# Do not expose Admin UI publicly without SSO / network control in staging/prod.
# UI_USERNAME=admin
# UI_PASSWORD=change-me

# =============================================================================
# PostgreSQL (required for virtual keys, teams, budgets, spend)
# =============================================================================
# Production features of the proxy require Postgres. Do not drop for "simplicity".

POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=litellm
POSTGRES_PORT=5432

# Required by compose for LiteLLM → Postgres. Password must be URL-encoded if it
# contains @ : / # ? etc. Prefer: uv run llg secrets generate (emits encoded URL).
# Host `postgres` is the Compose service name (use your host for external DB).
DATABASE_URL=postgresql://litellm:change-me-strong-db-password@postgres:5432/litellm

# =============================================================================
# Redis service (optional — container only via compose.redis.yaml / --redis-service)
# =============================================================================
# Starts Redis next to the stack. Does **not** inject REDIS_* into LiteLLM or
# enable shared Router / virtual-key limits (pin silent-degrade; see
# docs/evidence/spikes/2026-07-19-int-001-redis-pin-compat.md).
# Only REDIS_PASSWORD is required for the Redis container itself.

# REDIS_PORT=6379
# REDIS_PASSWORD=change-me-redis-password

# =============================================================================
# Provider API keys (proxy only — never put these in application env)
# =============================================================================
# Only set providers you actually route. Empty values are fine for unused families.
# YAML model routes reference these via os.environ/... — never paste keys into YAML.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
# Moonshot / Kimi (kimi-k2.6, kimi-k2.7-code routes)
MOONSHOT_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# COHERE_API_KEY=
# GROQ_API_KEY=

# =============================================================================
# Langfuse Cloud (default observability backend — not self-hosted here)
# =============================================================================
# Required for classic `langfuse` success/failure callbacks in litellm-config.yaml.
# Missing/invalid Langfuse credentials must not break the LLM path; fix telemetry
# separately. Rotate public/secret keys in the Langfuse project settings as needed.

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# UI/API host by region (use a separate project+keys for dev vs prod):
#   EU: https://cloud.langfuse.com
#   US: https://us.cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional OTEL ingest override when docs/plan require a distinct host from LANGFUSE_HOST.
# Often leave unset so the SDK/callback derives OTEL from LANGFUSE_HOST + keys.
# Example (only if your Langfuse setup documents a separate OTEL base):
# LANGFUSE_OTEL_HOST=https://cloud.langfuse.com

# =============================================================================
# Client examples / first-party app smoke (not the proxy container)
# =============================================================================
# Prefer a scoped virtual key over the master key for any application traffic.
# GatewayClient / examples refuse master when LLG_DISALLOW_MASTER is on (default).

LITELLM_VIRTUAL_KEY=
LITELLM_BASE_URL=http://localhost:4000/v1
# Optional model override for examples (default llm-general)
# LITELLM_MODEL=llm-general
#
# Master-key guard for app clients (src/llm_client, examples):
#   1 / true / unset → reject LITELLM_VIRTUAL_KEY when it equals (or is prefixed by)
#                      LITELLM_MASTER_KEY if that env is present in the process.
#   0 / false / off  → break-glass only; never ship master to apps/CI clients.
# LLG_DISALLOW_MASTER=1
