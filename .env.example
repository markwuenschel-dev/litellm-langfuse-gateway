# =============================================================================
# LiteLLM + Langfuse Gateway — environment template (repo-root DX copy)
# =============================================================================
# Canonical template (keep in sync when editing):
#   infra/llm-gateway/.env.example
#
# Copy to .env and fill real values. Never commit .env.
# Generate bootstrap secrets:
#   uv run python scripts/generate_secrets.py
#
# Non-secret env knobs: config/llm/environments/*.yaml
# Salt recovery: docs/llm-platform/incident-recovery.md
# =============================================================================

# --- LiteLLM proxy ---
# Master key: ADMIN BOOTSTRAP ONLY. Prefer virtual keys for applications.
LITELLM_MASTER_KEY=sk-change-me-master

# Salt key: PERMANENT encryption secret for proxy data at rest.
# Generate once per environment, store offline, never rotate casually.
# Lost salt → restore from offline backup; do not regenerate against existing DB.
# See docs/llm-platform/incident-recovery.md
LITELLM_SALT_KEY=sk-change-me-salt-permanent

# Optional override of the compose default pin (must include tag AND @sha256: digest).
# Default is set in infra/llm-gateway/compose.yaml — see infra/llm-gateway/upgrade-notes.md.
# LITELLM_IMAGE=ghcr.io/berriai/litellm:v1.92.0@sha256:9ef6f45bc0104940571765e610c52a1d761b5ec85efcd193795281086ee61277

# Proxy listen port (host)
LITELLM_PORT=4000

# Model registry: YAML (infra/llm-gateway/litellm-config.yaml) is source of truth.
# Keep false so Admin UI/DB model edits are not a second authority.
STORE_MODEL_IN_DB=False

# Optional UI credentials (if enabled by your LiteLLM version/image)
# UI_USERNAME=admin
# UI_PASSWORD=change-me

# --- PostgreSQL (required for keys, teams, budgets, spend) ---
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=litellm
POSTGRES_PORT=5432
# Compose builds DATABASE_URL from the above; override only if using external DB
# DATABASE_URL=postgresql://litellm:password@postgres:5432/litellm

# --- Redis (optional: multi-replica, distributed rate limits / routing state) ---
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=change-me-redis-password

# --- Provider API keys (proxy only; only set what you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# COHERE_API_KEY=
# GROQ_API_KEY=

# --- Langfuse Cloud (default observability backend) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# US cloud: https://us.cloud.langfuse.com
# EU cloud: https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional OTEL endpoint override if required by your Langfuse plan/setup
# LANGFUSE_OTEL_HOST=

# --- Client examples ---
# Prefer a scoped virtual key over the master key for app traffic
LITELLM_VIRTUAL_KEY=
LITELLM_BASE_URL=http://localhost:4000/v1
